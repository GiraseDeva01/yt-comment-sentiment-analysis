{
  "manifest_version": 3,
  "name": "YouTube Sentiment Analysis",
  "version": "1.0",
  "description": "Analyzes YouTube video comments for sentiment.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://10.12.242.1:8000/*",
    "http://127.0.0.1:8000/*",
    "https://www.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*"
  ]
}